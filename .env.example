# ============================================================
#  Multi-Agent Auto-Scheduling Platform  —  configuration
#  Copy this file to ".env" and fill in your own values.
#  NOTE: All LLM inference is LOCAL. There are no hosted-LLM keys here.
# ============================================================

# ---------- Local LLM (Ollama) ----------
# Start Ollama with:  ollama serve   then   ollama pull qwen3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
LLM_TIMEOUT_SECONDS=120

# ---------- Orchestrator / scheduler ----------
# Skip scheduling LLM jobs while the machine is under heavy load.
CPU_THROTTLE_PERCENT=85
RAM_THROTTLE_PERCENT=90
DISK_ALERT_PERCENT=90
# How long an agent may hold the single LLM lock before it is force-released.
LLM_LOCK_TIMEOUT_SECONDS=180

# ---------- Outbound e-mail (SMTP) ----------
# For Gmail use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=youraddress@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=youraddress@gmail.com
EMAIL_TO=youraddress@gmail.com

# ---------- AI-Times (YouTube Data API v3) ----------
# https://console.cloud.google.com -> APIs -> YouTube Data API v3 -> API key
YOUTUBE_API_KEY=your_youtube_api_key
AI_TIMES_QUERY=artificial intelligence
AI_TIMES_MAX_RESULTS=8

# ---------- Mailman (Gmail) & Calendar Optimizer (Google Calendar) ----------
# Place OAuth client secrets at the path below (downloaded from Google Cloud).
GOOGLE_CLIENT_SECRET_FILE=credentials/google_client_secret.json
GOOGLE_TOKEN_FILE=credentials/google_token.json

# ---------- Wallstreet Wolf ----------
# Comma-separated tickers (>= 20 required by the assignment).
STOCK_TICKERS=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,AMD,INTC,NFLX,ORCL,CRM,ADBE,CSCO,QCOM,IBM,AVGO,TXN,PYPL,UBER,JPM,V

# ---------- Schedules (24h clock, server local time) ----------
AI_TIMES_RUN_AT=08:00
MAILMAN_INTERVAL_MINUTES=15
WALLSTREET_RUN_AT=17:30
CALENDAR_RUN_AT=07:00

# ---------- Web dashboard ----------
WEB_HOST=127.0.0.1
WEB_PORT=8000
